let server = (\handshake .
  let (syn_seq, handshake) = receive handshake in
  let syn_ack_seq = 10 in
  let syn_ack_ack = (syn_seq + 1) in
  let syn_ack_pair = (syn_ack_seq, syn_ack_ack) in
  let handshake = send syn_ack_pair handshake in
  let (ack_pair, handshake) = receive handshake in
  let (ack_ack, ack_seq) = ack_pair in
  if ack_ack == (syn_ack_seq + 1)
  then
    if ack_seq == syn_ack_ack 
    then handshake
    else failure handshake
  else failure handshake) in

let client = fork server in
let client = send 42 client in
let (syn_ack_pair, client) = receive client in
let (syn_ack_seq, syn_ack_ack) = syn_ack_pair in
let ack_pair = (syn_ack_ack, syn_ack_seq + 1) in
let fail_pair = (999, 999) in
if syn_ack_ack == (42 + 1)
then
  let client = send ack_pair client in
  (wait client); true
else
  let client = send fail_pair client in
  (wait client); false
